{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native / Expo — JSX react-native, no DOM",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-native",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false
  }
}
