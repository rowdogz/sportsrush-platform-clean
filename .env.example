# =============================================================
# SportsRush 2.0 — Environment Variables Reference
# =============================================================
# Copy this file to .env and fill in real values for local work.
# NEVER commit a file with real values.
# See docs/runbooks/secrets.md for where to obtain each value.
# =============================================================

# --- Auth ---
# Signs and verifies JWT access tokens. Min 32 characters.
# Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-char-minimum-random-string

# --- Stripe ---
# Obtained from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Sports Data ---
# Commercial fixture/results API key (vendor TBD — see OD-14 in canonical rules)
SPORTS_API_KEY=replace_me

# --- Cloudflare (CI/CD only — not needed locally) ---
# Obtained from Cloudflare Dashboard → Profile → API Tokens
CLOUDFLARE_API_TOKEN=replace_me
CLOUDFLARE_ACCOUNT_ID=replace_me

# --- Environment identifier ---
# Set automatically by wrangler per environment. Do not set manually.
# Values: local | dev | staging | production
ENVIRONMENT=local
