{
  "name": "sportsrush",
  "private": true,
  "version": "0.0.1",
  "description": "SportsRush 2.0 monorepo",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml}\"",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf {} + 2>/dev/null; true"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.26.1"
}
